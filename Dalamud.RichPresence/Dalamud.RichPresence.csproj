<Project Sdk="Dalamud.NET.Sdk/15.0.0">
    <PropertyGroup>
        <AssemblyName>Dalamud.RichPresence</AssemblyName>
        <NoWarn>IDE0003</NoWarn>
        <AssemblyVersion>2.0.9.5</AssemblyVersion>
        <TargetFramework>net10.0-windows</TargetFramework>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference GeneratePathProperty="true" Include="DiscordRichPresence" Version="1.6.1.70" />
    </ItemGroup>

    <ItemGroup>
        <Content Remove="Resources/loc/*.json" />
    </ItemGroup>
    <ItemGroup>
        <None Condition=" '$(Configuration)' == 'Debug' " Include="icon.png">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <None Include="Resources/loc/*.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>
    <ItemGroup>
      <PackageReference Update="DotNet.ReproducibleBuilds" Version="2.0.5" />
    </ItemGroup>
</Project>